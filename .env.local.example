# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored — never commit real keys.

# Project Settings -> API -> Project URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=

# Project Settings -> API -> Publishable key (safe for the browser)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Project Settings -> API -> Secret key (server-only, never expose to the browser)
SUPABASE_SECRET_KEY=

# Finnhub API key (finnhub.io -> Dashboard -> API Key), server-only
FINNHUB_API_KEY=

# Alpha Vantage API key, server-only
ALPHAVANTAGE_API_KEY=

# Stripe test-mode keys. Never use live keys during local development.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
